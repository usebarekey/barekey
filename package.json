{
  "private": true,
  "license": "BSD-3-Clause",
  "workspaces": [
    "pkg/*"
  ],
  "scripts": {
    "convex:dev": "bunx convex dev",
    "convex:deploy": "bunx convex deploy",
    "auth:dev": "cd pkg/auth && bun run dev",
    "auth:build": "cd pkg/auth && bun run build",
    "auth:deploy": "cd pkg/auth && bun run cf:deploy",
    "api-proxy:dev": "cd pkg/api-proxy && wrangler dev",
    "api-proxy:deploy": "cd pkg/api-proxy && wrangler deploy",
    "ui:dev": "cd pkg/ui && bun run dev",
    "ui:build": "cd pkg/ui && bun run build",
    "ui:deploy": "cd pkg/ui && bun run cf:deploy",
    "test": "bun test tests",
    "lint": "oxlint --config .config/oxlint.json --ignore-path .config/.oxlintignore .",
    "lint:fix": "oxlint --config .config/oxlint.json --ignore-path .config/.oxlintignore --fix .",
    "format": "oxfmt --config .config/oxfmt.json --ignore-path .config/.oxfmtignore .",
    "format:check": "oxfmt --config .config/oxfmt.json --ignore-path .config/.oxfmtignore --check ."
  },
  "dependencies": {
    "@clerk/backend": "^2.32.1",
    "@effect/platform": "^0.94.5",
    "@noble/ciphers": "^2.1.1",
    "@noble/hashes": "^2.0.1",
    "@rjdellecese/confect": "^0.0.35",
    "@useautumn/convex": "^0.0.23",
    "autumn-js": "^0.1.81",
    "convex": "^1.32.0",
    "effect": "^3.19.19"
  },
  "devDependencies": {
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0"
  },
  "packageManager": "bun@1.2.22"
}
