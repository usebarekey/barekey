	"scripts": {
		"dev": "vp exec vite dev --configLoader runner",
		"build": "vp exec vite build",
		"preview": "vp exec vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "vp fmt . --check && vp lint vite.config.ts src/app.d.ts src/hooks.server.ts src/lib tests __tests__ && vp exec vite build && vp exec vitest run",
		"check:watch": "vp exec vitest watch",
		"fmt": "vp fmt . --write",
		"lint": "vp lint vite.config.ts src/app.d.ts src/hooks.server.ts src/lib tests __tests__",
		"test": "vp exec vitest run"
	},
